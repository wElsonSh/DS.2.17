---
// Массив навыков остался без изменений
const skills = [
	{ name: 'HTML5', level: 5 },
	{ name: 'CSS3 / SCSS', level: 5 },
	{ name: 'JavaScript', level: 2 },
	{ name: 'React', level: 3 },
	{ name: 'Tailwind', level: 4 },
	{ name: 'Git / GitHub', level: 3 },
]
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>DS.2.17 | Junior Developer Portfolio</title>
		<link rel='icon' type='image/svg+xml' href='img/favicon.svg' />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Bricolage+Grotesque:wght@600;800&family=Plus+Jakarta+Sans:wght@400;500&family=JetBrains+Mono&display=swap'
			rel='stylesheet'
		/>
	</head>
	<body>
		<div class='glow-layer'>
			<div class='blob blob-1'></div>
			<div class='blob blob-2'></div>
		</div>

		<main class='wrapper'>
			<header class='header'>
				<div class='logo-area'>
					<span class='logo-text'
						>DS.<span class='accent'>2.17</span></span
					>
				</div>
				<div class='nav-links'>
					<span class='availability'>
						<span class='pulse-dot'></span> Open for projects
					</span>
					<a href='mailto:seveldaiil@gmail.com' class='talk-btn'
						>Let's Talk</a
					>
				</div>
			</header>

			<section class='hero'>
				<div class='hero-top'>
					<span class='eyebrow'>// Web Developer Portfolio</span>
				</div>
				<h1 class='giant-title'>
					Turning pixels into<br />
					<span class='outline-text'>seamless logic.</span>
				</h1>

				<div class='hero-footer'>
					<div class='bio-box'>
						<p class='body-copy'>
							Hi! I’m Daniel. I’m a 17-year-old self-taught
							developer. I transform complex ideas into clean,
							functional digital products. Started at 13,
							currently mastering <strong>Full-Stack</strong>.
						</p>
					</div>
					<div class='stats-box'>
						<div class='stat-item'>
							<span class='num'>04</span>
							<span class='label'>Years focus</span>
						</div>
						<div class='stat-item'>
							<span class='num'>17</span>
							<span class='label'>Current age</span>
						</div>
					</div>
				</div>
			</section>

			<section class='stack-section'>
				<div class='section-header'>
					<h2 class='section-label'>Expertise</h2>
					<p class='mono-sub'>// Tech Stack Proficiency</p>
				</div>

				<div class='skills-grid'>
					{
						skills.map((skill) => (
							<div class='skill-item'>
								<span class='skill-name'>{skill.name}</span>
								<div class='level-indicator'>
									{[...Array(5)].map((_, i) => (
										<div
											class={`segment ${i < skill.level ? 'active' : ''}`}
										/>
									))}
								</div>
							</div>
						))
					}
				</div>
			</section>

			<section class='work-section'>
				<div class='work-content'>
					<div class='status-badge'>In Production</div>
					<h3 class='card-title'>Crafting something unique</h3>
					<p class='small-text'>
						I don't have any active projects at the moment, but you
						can take a look at my past projects.
					</p>
					<a href='https://github.com/wElsonSh' class='github-link'
						>github.com/wElsonSh ↗</a
					>
				</div>
			</section>

			<footer class='main-footer'>
				<div class='footer-line'></div>
				<div class='footer-content'>
					<div class='left'>
						<span class='mono'>HRODNO, BELARUS</span>
						<span class='mono'>
							LOCAL TIME <span
								id='belarus-time'
								class='time-accent'>00:00:00</span
							> — GMT+3
						</span>
					</div>
					<div class='right'>
						<span class='mono'
							>CREATOR BY NATURE, MINIMALIST BY DESIGN.</span
						>
					</div>
				</div>
			</footer>
		</main>

		<script is:inline>
			function updateTime() {
				const timeElement = document.getElementById('belarus-time')
				if (!timeElement) return
				const now = new Date()
				const belarusTime = new Intl.DateTimeFormat('en-GB', {
					timeZone: 'Europe/Minsk',
					hour: '2-digit',
					minute: '2-digit',
					second: '2-digit',
					hour12: false,
				}).format(now)
				timeElement.textContent = belarusTime
			}
			setInterval(updateTime, 1000)
			updateTime()
		</script>
	</body>
</html>

<style lang='scss'>
	$primary: #ff6b00;
	$secondary: #ffb200;
	$text: #ffffff;
	$text-muted: #cccccc;

	$font-huge: 'Syne', sans-serif;
	$font-head: 'Bricolage Grotesque', sans-serif;
	$font-body: 'Plus Jakarta Sans', sans-serif;
	$font-mono: 'JetBrains Mono', monospace;

	// Адаптивные отступы
	$section-margin: clamp(60px, 12vh, 120px);

	:global(html, body) {
		background-color: #050505;
		color: $text;
		margin: 0;
		padding: 0;
		font-family: $font-body;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
		width: 100%;

		background-image: url('/img/background.jpg');
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
	}

	.glow-layer {
		position: fixed;
		inset: 0;
		z-index: -1;
		filter: blur(100px);
		opacity: 0.4;
		pointer-events: none;

		.blob-1 {
			width: 60vw;
			height: 60vw;
			background: $primary;
			top: -15%;
			right: -10%;
			position: absolute;
			border-radius: 50%;
		}
		.blob-2 {
			width: 50vw;
			height: 50vw;
			background: #442200;
			bottom: -5%;
			left: -5%;
			position: absolute;
			border-radius: 50%;
		}
	}

	.wrapper {
		max-width: 1440px;
		margin: 0 auto;
		padding: 0 6vw;
		width: 100%;
		box-sizing: border-box;
	}

	/* HEADER */
	.header {
		height: clamp(80px, 10vh, 120px);
		display: flex;
		justify-content: space-between;
		align-items: center;

		.logo-text {
			font-family: $font-head;
			font-weight: 800;
			font-size: clamp(1.1rem, 2vw, 1.4rem);
			letter-spacing: -1px;
			white-space: nowrap;
			.accent {
				color: $primary;
			}
		}

		.nav-links {
			display: flex;
			align-items: center;
			gap: clamp(15px, 3vw, 35px);
		}

		.availability {
			font-family: $font-mono;
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 1px;
			display: flex;
			align-items: center;
			gap: 8px;

			@media (max-width: 550px) {
				display: none; // Прячем статус на совсем маленьких экранах
			}
			.pulse-dot {
				width: 6px;
				height: 6px;
				background: #00ff66;
				border-radius: 50%;
				box-shadow: 0 0 10px #00ff66;
			}
		}

		.talk-btn {
			background: $text;
			color: #000;
			padding: 10px 18px;
			border-radius: 8px;
			text-decoration: none;
			font-size: 0.8rem;
			font-weight: 700;
			transition: 0.3s;
			white-space: nowrap;
			&:hover {
				background: $primary;
				color: #fff;
			}
		}
	}

	/* HERO */
	.hero {
		margin-top: clamp(20px, 5vh, 60px);
		margin-bottom: $section-margin;

		.eyebrow {
			font-family: $font-mono;
			font-size: clamp(0.65rem, 1.5vw, 0.8rem);
			color: $primary;
			margin-bottom: 15px;
			display: block;
		}

		.giant-title {
			font-family: $font-huge;
			font-size: clamp(2.6rem, 11vw, 9.5rem);
			line-height: 0.85;
			letter-spacing: -0.05em;
			text-transform: uppercase;
			margin: 0;
			word-break: break-word;

			.outline-text {
				color: transparent;
				-webkit-text-stroke: clamp(1px, 0.2vw, 2px)
					rgba(255, 255, 255, 0.8);
			}
		}

		.hero-footer {
			margin-top: clamp(30px, 6vh, 60px);
			display: grid;
			grid-template-columns: 1.2fr 0.8fr;
			align-items: flex-start;
			gap: 40px;

			@media (max-width: 850px) {
				grid-template-columns: 1fr;
			}
		}

		.body-copy {
			font-size: clamp(1rem, 2vw, 1.25rem);
			line-height: 1.5;
			max-width: 520px;
			margin: 0;
			strong {
				color: $primary;
				font-weight: 600;
			}
		}

		.stats-box {
			display: flex;
			justify-content: flex-end;
			gap: clamp(30px, 5vw, 60px);

			@media (max-width: 850px) {
				justify-content: flex-start;
				border-top: 1px solid rgba(255, 255, 255, 0.1);
				padding-top: 30px;
			}

			.stat-item {
				.num {
					font-family: $font-head;
					font-size: clamp(2.5rem, 5vw, 3.5rem);
					color: $secondary;
					line-height: 1;
					display: block;
				}
				.label {
					font-family: $font-mono;
					font-size: 0.6rem;
					text-transform: uppercase;
					margin-top: 8px;
					display: block;
					opacity: 0.8;
				}
			}
		}
	}

	/* EXPERTISE */
	.stack-section {
		margin-bottom: $section-margin;

		.section-label {
			font-family: $font-head;
			font-size: clamp(1.2rem, 3vw, 1.6rem);
			text-transform: uppercase;
			margin: 0;
			letter-spacing: 2px;
		}

		.mono-sub {
			font-family: $font-mono;
			font-size: 0.7rem;
			color: $text-muted;
			margin: 10px 0 40px;
		}

		.skills-grid {
			display: grid;
			// Авто-сетка: минимум 250px, если не влезает — перенос
			grid-template-columns: repeat(
				auto-fill,
				minmax(min(100%, 280px), 1fr)
			);
			gap: clamp(15px, 3vw, 40px);
		}

		.skill-item {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 15px 0;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		}

		.skill-name {
			font-family: $font-head;
			font-size: clamp(0.95rem, 1.5vw, 1.1rem);
			font-weight: 600;
		}

		.level-indicator {
			display: flex;
			gap: 6px;
			.segment {
				width: clamp(8px, 1.5vw, 12px);
				height: clamp(8px, 1.5vw, 12px);
				background: rgba(255, 255, 255, 0.15);
				border-radius: 2px;
				&.active {
					background: $primary;
					box-shadow: 0 0 12px rgba($primary, 0.4);
				}
			}
		}
	}

	/* WORK */
	.work-section {
		margin-bottom: $section-margin;
		.status-badge {
			font-family: $font-mono;
			font-size: 0.65rem;
			color: $secondary;
			margin-bottom: 15px;
			text-transform: uppercase;
			letter-spacing: 2px;
			display: inline-block;
		}
		.card-title {
			font-family: $font-head;
			font-size: clamp(1.8rem, 5vw, 3.5rem);
			margin: 0 0 20px;
			line-height: 1.1;
		}
		.small-text {
			color: $text-muted;
			max-width: 540px;
			margin-bottom: 30px;
			font-size: clamp(1rem, 1.5vw, 1.15rem);
			line-height: 1.6;
		}
		.github-link {
			font-family: $font-mono;
			font-size: 0.9rem;
			color: $text;
			text-decoration: none;
			border-bottom: 2px solid $primary;
			padding-bottom: 4px;
			transition: 0.3s;
			&:hover {
				color: $primary;
			}
		}
	}

	/* FOOTER */
	.main-footer {
		padding-bottom: 40px;
		.footer-line {
			height: 1px;
			background: rgba(255, 255, 255, 0.371);
			margin-bottom: 30px;
		}
		.footer-content {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			gap: 30px;

			@media (max-width: 768px) {
				flex-direction: column;
				align-items: flex-start;
				text-align: left;
			}
		}
		.mono {
			font-family: $font-mono;
			font-size: 0.65rem;
			color: $text;
			display: block;
			letter-spacing: 1px;
			line-height: 2;
			opacity: 0.8;
		}
		.time-accent {
			color: $primary;
			font-weight: 600;
		}
	}
</style>
