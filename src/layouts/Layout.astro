---
import './Layout.scss'
import { SEO } from 'astro-seo'

interface Props {
	title?: string
	description?: string
	canonical?: string
	noindex?: boolean
	nofollow?: boolean
}

const {
	title = 'Daniel | Junior Full-Stack Developer',
	description = '17-year-old self-taught developer turning pixels into seamless logic.',
	canonical,
	noindex = false,
	nofollow = false,
} = Astro.props

// 1. Базовый URL сайта
const siteUrl = Astro.site?.origin || 'https://ds217.dev'

// 2. URL картинки и страницы
const ogImageUrl = new URL('/og-image.jpg', siteUrl).href
const pageUrl = canonical || new URL(Astro.url.pathname, siteUrl).href

const skills = [
	{ name: 'HTML5', level: 5 },
	{ name: 'CSS3 / SCSS', level: 5 },
	{ name: 'JavaScript', level: 2 },
	{ name: 'React', level: 3 },
	{ name: 'Tailwind', level: 4 },
	{ name: 'Git / GitHub', level: 3 },
]
---

<html lang='en'>
	<head>
		<SEO
			title={title}
			description={description}
			canonical={pageUrl}
			noindex={noindex}
			nofollow={nofollow}
			openGraph={{
				basic: {
					title: title,
					type: 'website',
					image: ogImageUrl,
					url: pageUrl,
				},
				optional: {
					description: description,
					siteName: 'DS.2.17 Portfolio',
				},
				image: {
					alt: 'DS.2.17 Portfolio Preview',
				},
			}}
			twitter={{
				card: 'summary_large_image',
				title: title,
				description: description,
				image: ogImageUrl,
			}}
			extend={{
				link: [{ rel: 'icon', href: '/img/favicon.svg' }],
				meta: [
					{
						name: 'viewport',
						content: 'width=device-width, initial-scale=1.0',
					},
					{ name: 'generator', content: Astro.generator },
				],
			}}
		/>

		<meta charset='utf-8' />
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Bricolage+Grotesque:wght@600;800&family=Plus+Jakarta+Sans:wght@400;500&family=JetBrains+Mono&display=swap'
			rel='stylesheet'
		/>
	</head>
	<body>
		<script is:inline>
			function updateTime() {
				const timeElement = document.getElementById('belarus-time')
				if (!timeElement) return
				const now = new Date()
				const belarusTime = new Intl.DateTimeFormat('en-GB', {
					timeZone: 'Europe/Minsk',
					hour: '2-digit',
					minute: '2-digit',
					second: '2-digit',
					hour12: false,
				}).format(now)
				timeElement.textContent = belarusTime
			}
			setInterval(updateTime, 1000)
			updateTime()
		</script>

		<div class='glow-layer'>
			<div class='blob blob-1'></div>
			<div class='blob blob-2'></div>
		</div>

		<main class='wrapper'>
			<header class='header'>
				<div class='logo-area'>
					<a href='/'>
						<span class='logo-text'>
							DS.<span class='accent'>2.17</span>
						</span>
					</a>
				</div>
				<div class='nav-links'>
					<span class='availability'>
						<span class='pulse-dot'></span> Open for projects
					</span>
					<a href='mailto:seveldaiil@gmail.com' class='talk-btn'
						>Let's Talk</a
					>
				</div>
			</header>

			<section class='hero'>
				<div class='hero-top'>
					<span class='eyebrow'>// Web Developer Portfolio</span>
				</div>
				<h1 class='giant-title'>
					Turning pixels into<br />
					<span class='outline-text'>seamless logic.</span>
				</h1>

				<div class='hero-footer'>
					<div class='bio-box'>
						<p class='body-copy'>
							Hi! I’m Daniel. I’m a 17-year-old self-taught
							developer. I transform complex ideas into clean,
							functional digital products. Started at 13,
							currently mastering <strong>Full-Stack</strong>.
						</p>
					</div>
					<div class='stats-box'>
						<div class='stat-item'>
							<span class='num'>04</span>
							<span class='label'>Years focus</span>
						</div>
						<div class='stat-item'>
							<span class='num'>17</span>
							<span class='label'>Current age</span>
						</div>
					</div>
				</div>
			</section>

			<section class='stack-section'>
				<div class='section-header'>
					<h2 class='section-label'>Expertise</h2>
					<p class='mono-sub'>// Tech Stack Proficiency</p>
				</div>

				<div class='skills-grid'>
					{
						skills.map((skill) => (
							<div class='skill-item'>
								<span class='skill-name'>{skill.name}</span>
								<div class='level-indicator'>
									{[...Array(5)].map((_, i) => (
										<div
											class={`segment ${i < skill.level ? 'active' : ''}`}
										/>
									))}
								</div>
							</div>
						))
					}
				</div>
			</section>

			<section class='work-section'>
				<div class='work-content'>
					<div class='status-badge'>In Production</div>
					<h3 class='card-title'>Crafting something unique</h3>
					<p class='small-text'>
						I don't have any active projects at the moment, but you
						can take a look at my past projects.
					</p>
					<a href='https://github.com/wElsonSh' class='github-link'>
						github.com/wElsonSh ↗
					</a>
				</div>
			</section>

			<footer class='main-footer'>
				<div class='footer-line'></div>
				<div class='footer-content'>
					<div class='left'>
						<span class='mono'>HRODNO, BELARUS</span>
						<span class='mono'>
							LOCAL TIME <span
								id='belarus-time'
								class='time-accent'>00:00:00</span
							> — GMT+3
						</span>
					</div>
					<div class='right'>
						<span class='mono'
							>CREATOR BY NATURE, MINIMALIST BY DESIGN.</span
						>
					</div>
				</div>
			</footer>
		</main>
	</body>
</html>
