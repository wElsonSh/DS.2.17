---
// Массив навыков с уровнем владения от 1 до 5
const skills = [
	{ name: 'HTML5', level: 5 },
	{ name: 'CSS3 / SCSS', level: 5 },
	{ name: 'JavaScript', level: 2 },
	{ name: 'React', level: 3 },
	{ name: 'Tailwind', level: 4 },
	{ name: 'Git / GitHub', level: 3 },
]
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width' />
		<title>DS.2.17 | Junior Developer Portfolio</title>
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Bricolage+Grotesque:wght@600;800&family=Plus+Jakarta+Sans:wght@400;500&family=JetBrains+Mono&display=swap'
			rel='stylesheet'
		/>
	</head>
	<body>
		<!-- Мягкие свечения поверх фона -->
		<div class='glow-layer'>
			<div class='blob blob-1'></div>
			<div class='blob blob-2'></div>
		</div>

		<main class='wrapper'>
			<!-- HEADER -->
			<header class='header'>
				<div class='logo-area'>
					<span class='logo-text'
						>DS.<span class='accent'>2.17</span></span
					>
				</div>
				<div class='nav-links'>
					<span class='availability'>
						<span class='pulse-dot'></span> Open for projects
					</span>
					<a href='mailto:seveldaiil@gmail.com' class='talk-btn'
						>Let's Talk</a
					>
				</div>
			</header>

			<!-- HERO SECTION -->
			<section class='hero'>
				<div class='hero-top'>
					<span class='eyebrow'>// Web Developer Portfolio</span>
				</div>
				<h1 class='giant-title'>
					Turning pixels into<br />
					<span class='outline-text'>seamless logic.</span>
				</h1>

				<div class='hero-footer'>
					<div class='bio-box'>
						<p class='body-copy'>
							Hi! I’m Danik. I’m a 17-year-old self-taught
							developer. I transform complex ideas into clean,
							functional digital products. Started at 13,
							currently mastering <strong>Full-Stack</strong>.
						</p>
					</div>
					<div class='stats-box'>
						<div class='stat-item'>
							<span class='num'>04</span>
							<span class='label'>Years focus</span>
						</div>
						<div class='stat-item'>
							<span class='num'>17</span>
							<span class='label'>Current age</span>
						</div>
					</div>
				</div>
			</section>

			<!-- EXPERTISE SECTION (БЕЗ КОРОБОК) -->
			<section class='stack-section'>
				<div class='section-header'>
					<h2 class='section-label'>Expertise</h2>
					<p class='mono-sub'>// Tech Stack Proficiency</p>
				</div>

				<div class='skills-grid'>
					{
						skills.map((skill) => (
							<div class='skill-item'>
								<span class='skill-name'>{skill.name}</span>
								<div class='level-indicator'>
									{[...Array(5)].map((_, i) => (
										<div
											class={`segment ${i < skill.level ? 'active' : ''}`}
										/>
									))}
								</div>
							</div>
						))
					}
				</div>
			</section>

			<!-- PROJECTS PLACEHOLDER (БЕЗ КОРОБОК) -->
			<section class='work-section'>
				<div class='work-content'>
					<div class='status-badge'>In Production</div>
					<h3 class='card-title'>Crafting something unique</h3>
					<p class='small-text'>
						Currently building several open-source tools and
						high-quality web applications. Follow the progress on
						GitHub.
					</p>
					<a href='https://github.com/wElsonSh' class='github-link'
						>github.com/wElsonSh ↗</a
					>
				</div>
			</section>

			<!-- FOOTER -->
			<footer class='main-footer'>
				<div class='footer-line'></div>
				<div class='footer-content'>
					<div class='left'>
						<span class='mono'>HRODNO, BELARUS</span>
						<span class='mono'>
							LOCAL TIME <span
								id='belarus-time'
								class='time-accent'>00:00:00</span
							> — GMT+3
						</span>
					</div>
					<div class='right'>
						<span class='mono'
							>CREATOR BY NATURE, MINIMALIST BY DESIGN.</span
						>
					</div>
				</div>
			</footer>
		</main>

		<script is:inline>
			function updateTime() {
				const timeElement = document.getElementById('belarus-time')
				if (!timeElement) return
				const now = new Date()
				const belarusTime = new Intl.DateTimeFormat('en-GB', {
					timeZone: 'Europe/Minsk',
					hour: '2-digit',
					minute: '2-digit',
					second: '2-digit',
					hour12: false,
				}).format(now)
				timeElement.textContent = belarusTime
			}
			setInterval(updateTime, 1000)
			updateTime()
		</script>
	</body>
</html>

<style lang='scss'>
	// Переменные
	$primary: #ff6b00;
	$secondary: #ffb200;
	$text: #ffffff;
	$text-muted: #cccccc; // Сделал чуть светлее для фона

	$font-huge: 'Syne', sans-serif;
	$font-head: 'Bricolage Grotesque', sans-serif;
	$font-body: 'Plus Jakarta Sans', sans-serif;
	$font-mono: 'JetBrains Mono', monospace;

	$section-margin: 110px;

	:global(html, body) {
		background-color: #050505;
		color: $text;
		margin: 0;
		font-family: $font-body;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;

		background-image: url('/img/background.jpg');
		background-size: cover;
		background-position: top;
		background-attachment: fixed;

		// Тень для всего текста на странице для читабельности на ярком фоне
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
	}

	.glow-layer {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: -1;
		filter: blur(120px);
		opacity: 0.45;
		.blob-1 {
			width: 50vw;
			height: 50vw;
			background: $primary;
			top: -10%;
			right: -5%;
			position: absolute;
			border-radius: 50%;
		}
		.blob-2 {
			width: 40vw;
			height: 40vw;
			background: #442200;
			bottom: 5%;
			left: 5%;
			position: absolute;
			border-radius: 50%;
		}
	}

	.wrapper {
		max-width: 1440px;
		margin: 0 auto;
		padding: 0 5vw;
	}

	.header {
		height: 100px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		.logo-text {
			font-family: $font-head;
			font-weight: 800;
			font-size: 1.3rem;
			letter-spacing: -1px;
			.accent {
				color: $primary;
			}
		}
		.nav-links {
			display: flex;
			align-items: center;
			gap: 30px;
		}
		.availability {
			font-family: $font-mono;
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 1px;
			color: $text;
			display: flex;
			align-items: center;
			gap: 8px;
			.pulse-dot {
				width: 6px;
				height: 6px;
				background: #00ff66;
				border-radius: 50%;
				box-shadow: 0 0 10px #00ff66;
			}
		}
		.talk-btn {
			background: $text;
			color: #000;
			padding: 10px 20px;
			border-radius: 8px;
			text-decoration: none;
			font-size: 0.85rem;
			font-weight: 600;
			transition: 0.3s;
			&:hover {
				opacity: 0.8;
			}
		}
	}

	.hero {
		margin-top: 50px;
		margin-bottom: $section-margin;
		.eyebrow {
			font-family: $font-mono;
			font-size: 0.75rem;
			color: $primary;
			margin-bottom: 20px;
			display: block;
		}
		.giant-title {
			font-family: $font-huge;
			font-size: clamp(3.5rem, 11vw, 9.5rem);
			line-height: 0.82;
			letter-spacing: -0.05em;
			text-transform: uppercase;
			margin: 0;
			.outline-text {
				color: transparent;
				-webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.8);
			}
		}
		.hero-footer {
			margin-top: 50px;
			display: grid;
			grid-template-columns: 1fr 1fr;
			align-items: flex-start;
			gap: 40px;
			@media (max-width: 768px) {
				grid-template-columns: 1fr;
			}
		}
		.body-copy {
			font-size: 1.15rem;
			line-height: 1.6;
			color: $text;
			max-width: 480px;
			margin: 0;
			strong {
				color: $primary;
				font-weight: 500;
			}
		}
		.stats-box {
			display: flex;
			justify-content: flex-end;
			gap: 60px;
			.stat-item {
				display: flex;
				flex-direction: column;
				.num {
					font-family: $font-head;
					font-size: 3rem;
					color: $secondary;
					line-height: 1;
				}
				.label {
					font-family: $font-mono;
					font-size: 0.65rem;
					color: $text;
					text-transform: uppercase;
					margin-top: 5px;
				}
			}
		}
	}

	.stack-section {
		margin-bottom: $section-margin;
		.section-label {
			font-family: $font-head;
			font-size: 1.5rem;
			color: $text;
			text-transform: uppercase;
			margin: 0;
			letter-spacing: 2px;
		}
		.mono-sub {
			font-family: $font-mono;
			font-size: 0.7rem;
			color: $text-muted;
			margin: 10px 0 40px;
		}

		.skills-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 30px;
		}

		.skill-item {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 10px 0;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		}

		.skill-name {
			font-family: $font-head;
			font-size: 1.1rem;
			font-weight: 600;
		}
		.level-indicator {
			display: flex;
			gap: 5px;
			.segment {
				width: 12px;
				height: 12px;
				background: rgba(255, 255, 255, 0.2);
				border-radius: 2px;
				&.active {
					background: $primary;
					box-shadow: 0 0 10px rgba($primary, 0.5);
				}
			}
		}
	}

	.work-section {
		margin-bottom: $section-margin;
		.work-content {
			max-width: 800px;
		}
		.status-badge {
			display: inline-block;
			font-family: $font-mono;
			font-size: 0.7rem;
			color: $secondary;
			margin-bottom: 20px;
			text-transform: uppercase;
			letter-spacing: 2px;
		}
		.card-title {
			font-family: $font-head;
			font-size: 3rem;
			margin-bottom: 15px;
		}
		.small-text {
			color: $text-muted;
			max-width: 500px;
			margin-bottom: 30px;
			font-size: 1.1rem;
			line-height: 1.5;
		}
		.github-link {
			font-family: $font-mono;
			color: $text;
			text-decoration: none;
			border-bottom: 2px solid $primary;
			padding-bottom: 4px;
			font-weight: 600;
			&:hover {
				color: $primary;
			}
		}
	}

	.main-footer {
		padding-bottom: 40px;
		.footer-line {
			height: 1px;
			background: rgba(255, 255, 255, 0.1);
			margin-bottom: 30px;
		}
		.footer-content {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			@media (max-width: 768px) {
				flex-direction: column;
				gap: 20px;
			}
		}
		.mono {
			font-family: $font-mono;
			font-size: 0.7rem;
			color: $text;
			display: block;
			letter-spacing: 1px;
			line-height: 1.8;
		}
		.time-accent {
			color: $primary;
			font-weight: 600;
		}
	}
</style>
